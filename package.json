{
  "name": "ghostbrowse",
  "version": "1.0.0",
  "description": "GhostBrowse 指纹浏览器 - 基于 Electron + Vue 3 + TypeScript",
  "main": "dist-electron/main/index.js",
  "author": "GhostBrowse Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite --port 5173",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main && electron-builder",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:electron": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "electron": "^33.4.11",
    "express": "^4.21.1",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^9.0.0",
    "proxy-agent": "^8.0.1",
    "socks-proxy-agent": "^7.0.0",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/http-cache-semantics": "^4.2.0",
    "@types/http-errors": "^2.0.5",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.8.1",
    "@types/qs": "^6.15.0",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^1.2.1",
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.1.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.10"
  }
}
