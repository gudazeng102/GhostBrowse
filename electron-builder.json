{
  "productName": "GhostBrowse",
  "appId": "com.ghostbrowse.app",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "src/main/browser/extension/",
      "to": "extension/",
      "filter": ["**/*"]
    },
    {
      "from": "resources/",
      "to": "resources/"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName} Setup ${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "GhostBrowse",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico"
  },
  "asar": true,
  "compression": "maximum"
}
